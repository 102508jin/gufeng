{
  "name": "wenyan-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx scripts/dev-server.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval:quality": "tsx scripts/evaluate-quality.ts",
    "ingest:personas": "tsx scripts/ingest-personas.ts",
    "ingest:knowledge": "tsx scripts/ingest-knowledge.ts",
    "reindex": "tsx scripts/rebuild-index.ts",
    "verify": "npm run ingest:knowledge && npm run reindex && npm test && npm run eval:quality && npm run build"
  },
  "dependencies": {
    "next": "^15.3.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "prisma": "^6.6.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
